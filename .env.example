# Supabase プロジェクトの URL
# Supabase ダッシュボード → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon (public) key
# Supabase ダッシュボード → Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Supabase service role key（サーバー側のみで使用。絶対に公開しないこと）
# Supabase ダッシュボード → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- メール通知 (Resend) ---------------------------------------------
# Resend API キー（サーバー側のみ。公開しないこと）
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# 送信元アドレス（Resend で検証済みのドメインを使う）
# 動作確認だけなら Resend のテスト用 onboarding@resend.dev が使えます。
RESEND_FROM=あとで解約 <onboarding@resend.dev>

# --- 通知バッチ (Vercel Cron) ----------------------------------------
# Cron エンドポイントの認証に使う秘密鍵（推測されない十分長い文字列）
# 生成例: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# メール内の詳細ページリンクに使うアプリのURL
# 本番では https://your-app.vercel.app を設定。未設定時は VERCEL_URL を利用。
NEXT_PUBLIC_APP_URL=http://localhost:3000
